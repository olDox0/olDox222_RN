_VOCAB_ENTRY_FMT_V3 = "<IQI"   # token_id(u32), offset(u64), df(u32)
_VOCAB_ENTRY_SIZE_V3 = struct.calcsize(_VOCAB_ENTRY_FMT_V3)  # 4+8+4 = 16 bytes



