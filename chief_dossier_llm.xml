def emit_forensic_log(exc: Exception, func_name: str = "Unknown") -> None:
    """Emite log forense detalhado sem quebrar o fluxo."""
    _, _, exc_tb = sys.exc_info()
    f_name = os.path.split(exc_tb.tb_frame.f_code.co_filename)[1] if exc_tb else "Unknown"
    line_n = exc_tb.tb_lineno if exc_tb else 0
    
    print(f"\033[1;34m[ FORENSIC ]\033[0m \033[1mFile: {f_name} | L: {line_n} | Func: {func_name}\033[0m\n"
          f"\033[31m  ■ Type: {type(exc).__name__} | Value: {exc}\033[0m")
