Telemetria fina de inferência: spans por etapa + derivados.

OSL-4:  Um método, uma responsabilidade.
OSL-6:  Spans imutáveis após end() — sem modificação retroativa.
OSL-15: Fail-silent: erros de gravação nunca interrompem o fluxo principal.
OSL-18: stdlib only (json, pathlib, time).
God: Cronos — mede tudo, não atrasa nada.

Arquivo de saída: telemetry/profiler.jsonl
Schema de uma entrada:

{
  "v": 1,
  "ts": 1773410362,          -- unix timestamp de início
  "query_chars": 12,         -- chars da query pura (user turn)
  "system_hint_chars": 22,   -- chars do bloco de síntese (system turn)
  "prompt_built_chars": 181, -- chars do ChatML completo montado
  "token_hint": 43,          -- estimativa de tokens enviada ao bridge

  "spans_ms": {
    "load_check":    0.3,    -- _ensure_loaded() (≈0 se modelo já estava na RAM)
    "ctx_push":      0.1,    -- ContextWindow.push() incluindo sliding window
    "prompt_build":  0.4,    -- _build_prompt() (monta ChatML completo)
    "llm_call":   57921.0,   -- _call_engine() — decode puro no llama.cpp
    "text_parse":    0.1,    -- extração do texto e usage do dict de retorno
    "memo_lookup":   0.0,    -- _memo_get() (cache de repetição)
    "memo_store":    0.1,    -- _memo_put() após resposta
    "total":      57923.1    -- monotonic total (pode incluir gaps menores)
  },

  "derived": {
    "overhead_ms":       2.1,   -- total - llm_call
    "overhead_pct":      0.0,   -- overhead / total * 100
    "ms_per_token":   1316.4,   -- llm_call / completion_tokens
    "ttft_est_ms":     880.0,   -- estimativa TTFT = prompt_tokens * ms_per_prompt_token
    "prompt_eval_share_pct": 1.5  -- % do llm_call gasto em prompt eval (estimado)
  },

  "counters": {
    "prompt_tokens":     44,
    "completion_tokens": 44,
    "total_tokens":      88,
    "tokens_per_second": 0.76,
    "context_turns":      2,
    "active_window_used": 204,   -- janela efetiva após token_hint
    "active_window_cfg":  512,   -- janela configurada em BridgeConfig
    "memo_hit": false            -- true se respondeu do cache
  },

  "hw": {
    "n_ctx":     1024,
    "n_threads":    2,
    "n_gpu_layers": 0
  }
}
"""

from __future__ import annotations

import json
import time
from dataclasses import dataclass, field
from pathlib import Path
from typing import Any


# ---------------------------------------------------------------------------
# Span — unidade de medição
# ---------------------------------------------------------------------------

@dataclass
class Span:
    """Intervalo de tempo de uma etapa do pipeline.

    Attributes:
        name:    Identificador da etapa.
        start_s: Timestamp de início (perf_counter).
        end_s:   Timestamp de fim (perf_counter). None até end().
    """
    name:    str
    start_s: float
    end_s:   float | None = None

    def end(self) -> "Span":
        """Finaliza o span. Idempotente."""
        if self.end_s is None:
            self.end_s = time.perf_counter()
        return self

    @property
    def ms(self) -> float:
        """Duração em milissegundos. 0.0 se não finalizado."""
        if self.end_s is None:
            return 0.0
        return round((self.end_s - self.start_s) * 1000.0, 3)


# ---------------------------------------------------------------------------
# InferenceProfiler
# ---------------------------------------------------------------------------

class InferenceProfiler:
    """Coleta spans de uma inferência e grava telemetria fina.

    Uso no bridge:
        prof = InferenceProfiler(output_path)
        prof.begin(query_chars, system_hint_chars, token_hint)

        with prof.span("load_check"): self._ensure_loaded()
        with prof.span("ctx_push"):   self._ctx.push("user", prompt)
        with prof.span("prompt_build"): built = self._build_prompt()
        with prof.span("llm_call"):   resp = self._call_engine(built, max_t)
        # ... etc

        prof.finish(usage, prompt_built_chars, active_window_used,
                    active_window_cfg, context_turns, hw)

    OSL-15: finish() é fail-silent — nunca lança exceção.
    OSL-3:  _spans é limpo em begin() — sem acúmulo entre chamadas.
    """

    _KNOWN_SPANS = frozenset({
        "load_check", "ctx_push", "prompt_build",
        "llm_call", "text_parse", "memo_lookup", "memo_store",
    })

    def __init__(self, output_path: Path | None = None) -> None:
        self._path     = output_path or Path("telemetry/profiler.jsonl")
        self._spans:   dict[str, Span] = {}
        self._t_begin: float = 0.0
        self._meta:    dict[str, Any] = {}

    # ------------------------------------------------------------------
    # Ciclo de vida
    # ------------------------------------------------------------------

    def begin(
        self,
        query_chars:       int = 0,
        system_hint_chars: int = 0,
        token_hint:        int | None = None,
    )
